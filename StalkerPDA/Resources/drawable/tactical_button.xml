<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_pressed="true">
		<shape android:shape="rectangle">
			<gradient
                android:startColor="#664A3B22"
                android:endColor="#AA4A3B22"
                android:angle="270" />
			<stroke android:width="1.5dp" android:color="#FFC107" />
			<corners android:radius="2dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<gradient
                android:startColor="#2D2A24"
                android:endColor="#14120E"
                android:angle="270" />
			<stroke android:width="1dp" android:color="#3A4035" />
			<corners android:radius="2dp" />
		</shape>
	</item>
</selector>