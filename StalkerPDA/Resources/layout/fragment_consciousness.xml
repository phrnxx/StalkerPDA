<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

	<!-- Заголовок -->
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#121210">

		<TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="// о-свідомість · llm термінал"
            android:textColor="#5A4820"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>

		<TextView
            android:id="@+id/consciousness_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● GEMINI"
            android:textColor="#C8A040"
            android:textSize="9sp"
            android:fontFamily="monospace"/>
	</LinearLayout>

	<View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A1E"/>

	<!-- Діалог з ШІ -->
	<ListView
        android:id="@+id/consciousness_list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#1E1E14"
        android:dividerHeight="1dp"
        android:stackFromBottom="true"
        android:transcriptMode="alwaysScroll"
        android:padding="8dp"
        android:scrollbars="none"/>

	<View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A1E"/>

	<!-- Input -->
	<LinearLayout
        android:id="@+id/input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#121210"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

		<TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="›"
            android:textColor="#C8A040"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingRight="6dp"/>

		<EditText
            android:id="@+id/consciousness_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:textColor="#D4C090"
            android:hint="Введіть запит до О-Свідомості..."
            android:textColorHint="#3A3020"
            android:padding="8dp"
            android:textSize="13sp"
            android:maxLines="2"
            android:fontFamily="monospace"/>

		<Button
            android:id="@+id/btn_consciousness_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXECUTE"
            android:background="@android:color/transparent"
            android:textColor="#C8A040"
            android:textStyle="bold"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:padding="8dp"/>
	</LinearLayout>

</LinearLayout>