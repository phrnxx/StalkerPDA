<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pda_bg">

	<FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/nav_buttons"
        android:layout_marginTop="90dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp" />

	<LinearLayout
        android:id="@+id/nav_buttons"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:orientation="horizontal"
        android:weightSum="5">

		<Button
            android:id="@+id/btn_quests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="КВЕСТИ"
            android:textColor="#00BFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

		<Button
            android:id="@+id/btn_network"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="МЕРЕЖА"
            android:textColor="#00BFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

		<Button
            android:id="@+id/btn_news"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="НОВИНИ"
            android:textColor="#00BFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

		<Button
            android:id="@+id/btn_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="ЗОНА"
            android:textColor="#00BFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

		<Button
            android:id="@+id/btn_consciousness"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="О-СВІД."
            android:textColor="#00BFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />
	</LinearLayout>

	<ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/pda_bg_glass"
        android:scaleType="centerCrop"
        android:alpha="0.25"
        android:clickable="false"
        android:focusable="false" />

</RelativeLayout>