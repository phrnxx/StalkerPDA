<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0A0A08"
    android:padding="4dp">

	<LinearLayout
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#14120E"
        android:padding="10dp"
        android:layout_marginRight="4dp">

		<TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="P.D.A. OS v3.0"
            android:textColor="#8C9485"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="25dp"/>

		<Button
            android:id="@+id/tab_quests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ЗАВДАННЯ"
            android:textColor="#E5B15D"
            android:background="@drawable/tactical_button"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

		<Button
            android:id="@+id/tab_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="КАРТА ЗОНИ"
            android:textColor="#E5B15D"
            android:background="@drawable/tactical_button"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

		<Button
            android:id="@+id/tab_network"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="МЕРЕЖА"
            android:textColor="#E5B15D"
            android:background="@drawable/tactical_button"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

		<Button
            android:id="@+id/tab_consciousness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="О-СВІДОМІСТЬ"
            android:textColor="#E5B15D"
            android:background="@drawable/tactical_button"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

		<Button
            android:id="@+id/tab_database"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="БАЗА ДАНИХ"
            android:textColor="#E5B15D"
            android:background="@drawable/tactical_button"
            android:padding="12dp"/>
	</LinearLayout>

	<FrameLayout
        android:id="@+id/main_fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#14120E" />

</LinearLayout>