<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0A0A08">

	<LinearLayout
        android:layout_width="165dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#121210"
        android:padding="10dp">

		<TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="P.D.A."
            android:textColor="#C8A040"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:layout_marginBottom="2dp"/>

		<TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OS v3.0"
            android:textColor="#5A4820"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

		<TextView
            android:id="@+id/sidebar_clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#D4C090"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

		<ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

			<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="4dp">

				<Button
                    android:id="@+id/tab_quests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ЗАВДАННЯ"
                    android:layout_marginBottom="6dp"
                    style="@style/Widget.Stalker.Button" />

				<Button
                    android:id="@+id/tab_map"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="КАРТА ЗОНИ"
                    android:layout_marginBottom="6dp"
                    style="@style/Widget.Stalker.Button" />

				<Button
                    android:id="@+id/tab_network"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="МЕРЕЖА"
                    android:layout_marginBottom="6dp"
                    style="@style/Widget.Stalker.Button" />

				<Button
                    android:id="@+id/tab_news"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="НОВИНИ"
                    android:layout_marginBottom="6dp"
                    style="@style/Widget.Stalker.Button" />

				<Button
                    android:id="@+id/tab_consciousness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="С-СВІДОМІСТЬ"
                    android:layout_marginBottom="6dp"
                    style="@style/Widget.Stalker.Button" />

				<Button
                    android:id="@+id/tab_database"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="БАЗА ДАНИХ"
                    style="@style/Widget.Stalker.Button" />
			</LinearLayout>
		</ScrollView>

		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">
			<TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ЗАРЯД"
                android:textColor="#5A4820"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
			<TextView
                android:id="@+id/sidebar_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--%"
                android:textColor="#C87030"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
		</LinearLayout>

		<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
			<TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="РАД/ГОД"
                android:textColor="#5A4820"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
			<TextView
                android:id="@+id/sidebar_signal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#C8A040"
                android:textSize="9sp"
                android:fontFamily="monospace"/>
		</LinearLayout>
	</LinearLayout>

	<FrameLayout
        android:id="@+id/main_fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#0A0A08" />

</LinearLayout>